# Zufälliger, geheimer String zum Signieren der Login-Session.
# Generieren z. B. mit: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=

# Aus der Google Cloud Console (OAuth-Client vom Typ "Web-Anwendung").
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Kommagetrennte Liste der Google-Konten (E-Mail-Adressen), die Zugriff erhalten sollen.
ALLOWED_EMAILS=beispiel@gmail.com
